@model InzV3.Models.TicketModel
@{
    ViewBag.Title = "Szczegóły zgłoszenia #" + Model.id_ticket;
    Layout = "~/Views/Shared/_Layout.cshtml";
    bool isTechOrAdmin = ViewBag.IsTechOrAdmin;
    string currentUserId = ViewBag.CurrentUserId;
}

<div class="mt-4 mb-4 d-flex justify-content-between align-items-center">
    <h2>Zgłoszenie #@Model.id_ticket <span class="badge bg-dark fs-6 ms-2">@Model.status</span></h2>
    <a class="btn btn-secondary" href="@Url.Action(isTechOrAdmin ? "ManageTickets" : "MyTickets", "Tickets")">Powrót</a>
</div>


<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light fw-bold">Szczegóły</div>
            <div class="card-body">
                <p><strong>Data zgłoszenia:</strong> @Model.createdAt.ToString("dd.MM.yyyy HH:mm")</p>
                <p><strong>Ostatnia aktualizacja:</strong> @Model.updatedAt.ToString("dd.MM.yyyy HH:mm")</p>
                <p><strong>Zgłaszający:</strong> <br />@Model.User.FirstName @Model.User.LastName (@Model.User.Email)</p>
                <hr />
                <p><strong>Sprzęt:</strong><br /><a href="@Url.Action("Details", isTechOrAdmin ? "Devices":"UserDevice", new { id = Model.id_device})">@Model.Device.brand @Model.Device.model @Model.Device.model (S/N: @Model.Device.serial_num)</a></p>
                <hr />
                <p><strong>Wstępny opis:</strong></p>
                <div class="alert alert-secondary">@Model.description</div>
            </div>
        </div>
        @if (isTechOrAdmin) 
        {
            <div class="card shadow-sm border-warning mb-4">
                <div class="card-header bg-warning fw-bold text-dark"> Panel Serwisanta</div>
                <div class="card-body">
                    <p><strong>Obecny opiekun:</strong>@(Model.Technician!=null ? Model.Technician.FirstName+" "+ Model.Technician.LastName:"Brak")</p>
                    @if (Model.status != InzV3.Models.TicketStatuses.Zamkniete)
                    {
                        if (Model.id_technician != currentUserId)
                        {
                            using (Html.BeginForm("AssignToMe", "Tickets", FormMethod.Post, new { @class = "mb-3" }))
                            {
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id_ticket" value="@Model.id_ticket" />
                                <button type="submit" class="btn btn-primary w-100">@(Model.id_technician==null ? "Przypisz do mnie" : "Przejmij zgłoszenie")</button>
                            }
                        }
                        if (Model.id_technician == currentUserId)
                        {
                            using (Html.BeginForm("ChangeStatus", "Tickets", FormMethod.Post))
                            {
                                @Html.AntiForgeryToken()
                                <input type = "hidden" name = "id_ticket" value = "@Model.id_ticket"/>
                                <div class="input-group">
                                    @Html.DropDownList("newStatus", (SelectList)ViewBag.StatusList, new { @class = "form-select" })
                                    <button type="submit" class="btn btn-outline-dark">Zmień status</button>
                                </div>

                            }
                        }
                    }
                </div>
            </div>
        }
    </div>
    <div class="col-md-8">
        <div class="card shadow-sm h-100 d-flex flex-column">
            <div class="card-header bg-primary text-white fw-bold"><i class="bi bi-chat-dots"></i> Konwersacja</div>
            <div class="card-body flex-grow-1" style="max-height: 500px; overflow-y:auto;">
                @if (!Model.Messages.Any())
                {
                    <p class="text-muted text-center mt-4"> Brak wiadomości.</p>
                }
                @foreach (var msg in Model.Messages)
                {
                    bool isMe = msg.id_sender == currentUserId;
                    <div class="mb-3 @(isMe ? "text-end" : "text-start")">
                        <small class="text-muted">@msg.Sender.FirstName @msg.Sender.LastName - @msg.createdAt.ToString("HH:mm dd.MM")</small>
                        <div class="p-3 rounded-3 mt-1 d-inline-block @(isMe ? "bg-primary text-white" : "bg-light border")" style="max-width: 75%; text-align: left;">
                            @msg.messageContent
                        </div>
                    </div>

                }


            </div>

            <div class="card-footer bg-white p-3">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                }
                @if (Model.status == InzV3.Models.TicketStatuses.Zamkniete)
                {
                    <div class="alert alert-secondary mb-0 text-center">Zgłoszenie jest zamkniete</div>
                }
                else if (!isTechOrAdmin)
                {
                    if (Model.status == InzV3.Models.TicketStatuses.OczekujeUser)
                    {
                        using (Html.BeginForm("SendMessage", "Tickets", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id_ticket" value="@Model.id_ticket" />
                            <div class="input-group">
                                <textarea name="messageContent" class="form-control" rows="2" placeholder="Odpowiedz" required></textarea>
                                <button type="submit" class="btn btn-primary px-4">Wyślij</button>
                            </div>

                        }
                    }
                    else
                    {
                        <div class="alert alert-info mb-0 text-center">Oczekuj na informacje od serwisu</div>
                    }
                }
                else
                {
                    if (Model.id_technician != currentUserId)
                    {
                        <div class="alert alert-warning mb-0 text-center">Musisz przypisać zgłoszenie do siebie, aby odpowiedzieć</div>
                    }
                    else if (Model.status == InzV3.Models.TicketStatuses.OczekujeUser)
                    {
                        <div class="alert alert-info mb-0 text-center">Poczekaj na wiadomość użytkownika</div>
                    }
                    else
                    {
                        using (Html.BeginForm("SendMessage", "Tickets", FormMethod.Post))
                        {
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id_ticket" value="@Model.id_ticket" />
                            <div class="input-group">
                                <textarea name="messageContent" class="form-control" rows="2" placeholder="Odpowiedz" required></textarea>
                                <button type="submit" class="btn btn-primary px-4">Wyślij</button>
                            </div>

                        }
                    }
                }
            </div>
        </div>
    </div>
</div>