@model InzV3.Models.SoftwareModel
@{
    ViewBag.Title = "Zarządzaj oprogramowaniem";
}

<h2 class="mt-4"><i class="bi bi-pencil-square"></i> Zarządzaj: @Model.software_name</h2>
<hr />

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    @* Pola ukryte - konieczne, aby model był kompletny przy wysyłaniu formularza *@
    @Html.HiddenFor(m => m.id_software)
    @Html.HiddenFor(m => m.software_name)
    @Html.HiddenFor(m => m.software_serial_number)
    @Html.HiddenFor(m => m.license_key)
    @Html.HiddenFor(m => m.software_category)

    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-4 border-dark">
                <div class="card-header bg-dark text-white">Szczegóły oprogramowania</div>
                <div class="card-body bg-light">
                    <p class="mb-1"><strong>Nazwa:</strong> @Model.software_name</p>
                    <p class="mb-1"><strong>Kategoria:</strong> @Model.software_category</p>
                    <p class="mb-1"><strong>S/N:</strong> @(string.IsNullOrEmpty(Model.software_serial_number) ? "-" : Model.software_serial_number)</p>
                    <p class="mb-0"><strong>Klucz:</strong> @(string.IsNullOrEmpty(Model.license_key) ? "Brak w bazie" : Model.license_key)</p>
                </div>
            </div>

            <div class="form-group mb-3">
                <label class="form-label fw-bold">Data końca licencji</label>
                @Html.EditorFor(m => m.license_end_date, new { htmlAttributes = new { @class = "form-control", type = "date" } })
                @Html.ValidationMessageFor(m => m.license_end_date, "", new { @class = "text-danger" })
                <small class="text-muted d-block mt-1">Jeśli licencja jest dożywotnia (Lifetime), pozostaw to pole puste.</small>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-warning shadow-sm h-100">
                <div class="card-header bg-warning text-dark fw-bold">Zmiana przypisanego sprzętu</div>
                <div class="card-body d-flex flex-column">
                    <label class="form-label small">Numer seryjny urządzenia do przypisania:</label>
                    <div class="input-group mb-3">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text" id="devSerial" class="form-control" value="@ViewBag.CurrentDeviceSerial" placeholder="Wpisz S/N urządzenia..." autocomplete="off">
                    </div>

                    <div id="devPreview" class="alert alert-secondary d-none">
                    </div>

                    @* Ukryte pole trzymające ID sprzętu dla bazy *@
                    @Html.HiddenFor(m => m.assigned_device, new { id = "targetId" })

                    <div class="mt-auto">
                        <button type="button" id="clearBtn" class="btn btn-outline-danger btn-sm w-100">
                            <i class="bi bi-x-circle"></i> Odłącz obecne urządzenie
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-warning px-5 fw-bold shadow-sm">Zapisz zmiany</button>
        @Html.ActionLink("Anuluj i wróć", "Index", null, new { @class = "btn btn-outline-secondary ms-2" })
    </div>
}

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <script>
        $(document).ready(function() {
            function findDevice(serial) {
                if(serial.length > 2) {
                    $.get('@Url.Action("GetDeviceInfo", "Software")', { serial: serial }, function(res) {
                        $('#devPreview').removeClass('d-none');
                        if(res.success) {
                            $('#devPreview').removeClass('alert-danger alert-secondary').addClass('alert-success');
                            $('#devPreview').html('<strong>✓ Dopasowano:</strong> ' + res.brand + ' ' + res.model + ' (ID: ' + res.id + ')');
                            $('#targetId').val(res.id);
                        } else {
                            $('#devPreview').removeClass('alert-success alert-secondary').addClass('alert-danger');
                            $('#devPreview').html('Nie znaleziono sprzętu o podanym numerze seryjnym.');
                            $('#targetId').val('');
                        }
                    });
                } else {
                    $('#devPreview').addClass('d-none');
                    $('#targetId').val('');
                }
            }

            $('#devSerial').on('input', function() {
                findDevice($(this).val());
            });

            $('#clearBtn').click(function() {
                $('#devSerial').val('');
                $('#targetId').val('');
                $('#devPreview').addClass('d-none');
            });

            // Sprawdzenie na starcie dla edycji
            if($('#devSerial').val() !== "") {
                findDevice($('#devSerial').val());
            }
        });
    </script>
}