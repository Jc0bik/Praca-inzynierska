@model IEnumerable<InzV3.Models.DevFeature>
@{
    ViewBag.Title = "Cechy szczególne urządzeń";
}

<div class="mt-4">

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Uwaga!</strong> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zamknij"></button>
        </div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Zamknij"></button>
        </div>
    }
    <h2>Zarządzenie cechami szczególnymi</h2>
    <p>
        @Html.ActionLink("Wróć", "Index", "Admin", null, new { @class = "btn btn-secondary" })
        @Html.ActionLink("Dodaj nową cechę", "Create", null, new { @class = "btn btn-success" })
    </p>
    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Nazwa cechy</th>
                <th style="width:150px;">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle">@Html.DisplayFor(modelItem => item.dev_feature_name)</td>
                    <td>
                        <button type="button" class="btn btn-danger me-1" onclick="openDeleteModal('@item.id_dev_feature', '@item.dev_feature_name')">
                            Usuń
                        </button>

                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<div class="modal fade text-start" id="globalDeleteModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Potwierdzenie usunięcia</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Czy na pewno chcesz usunąć cechę:<strong id="deleteFName"></strong>?<br />
                <span class="text-muted" style="font-size:0.9em;">(Ta operacja jest nieodwracalna)</span>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                @using (Html.BeginForm("Delete", "DevFeatures", new { id = 0 }, FormMethod.Post, new { style = "margin: 0;" }))
                {
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" id="deleteFId" />
                    <button type="submit" class="btn btn-danger">Tak, usuń</button>
                })
            </div>
        </div>
    </div>
</div>
@section Scripts{
    <script>
        function openDeleteModal(featureId, featureName) {
            document.getElementById('deleteFName').textContent = featureName;


            var deleteUrl = '@Url.Action("Delete", "DevFeatures")' + '/' + featureId;
            document.getElementById('confirmDeleteBtn').href = deleteUrl;


            var deleteModal = new bootstrap.Modal(document.getElementById('globalDeleteModal'));
            deleteModal.show();
        }
    </script>
}    