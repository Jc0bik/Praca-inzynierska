@model InzV3.Models.SubRoleModel
@{
    ViewBag.Title = "Dodaj podrolę";
}

<div class="mt-4">
    <h2>Dodaj nową podrolę</h2>
    <hr />
    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger fw-bold mb-3" })

        <div class="form-group row mb-3">
            <label class="col-md-2 col-form-label fw-bold">Rola nadrzędna</label>
            <div class="col-md-6">
                @Html.DropDownListFor(m => m.RoleId, (ViewBag.ParentRoles as SelectList), "Wybierz rolę nadrzędną", new { @class = "form-select", required = "required" })
            </div>
        </div>
        <div class="form-group row mb-3">
            <label class="col-md-2 col-form-label fw-bold">Nazwa podroli</label>
            <div class="col-md-6">
                @Html.TextBoxFor(m => m.Name, new { @class = "form-control", required = "required", placeholder = "Programistra, Przedstawiciel handlowy..." })
            </div>
        </div>
        <div class="form-group row mb-3">
            <label class="col-md-2 col-form-label fw-bold">Częstotliwość ocen (dni)</label>
            <div class="col-md-6">
                @Html.TextBoxFor(m => m.RatingIntervalDays, new { @class = "form-control", type="number", min="0", required = "required"})
            </div>
        </div>

        <div class="mt-3">
            <input type="submit" value="Zapisz" class="btn btn-primary" />
            @Html.ActionLink("Anuluj", "Index", null, new { @class = "btn btn-secondary ms-2" })
        </div>
    }
</div>

