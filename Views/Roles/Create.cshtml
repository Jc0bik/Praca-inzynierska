
@{
    ViewBag.Title = "Dodaj rolę użytk";
}

<div class="mt-4">
    <h2>Dodaj nową rolę</h2>
    <hr />
    @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()
                @Html.ValidationSummary(true, "", new {@class = "text-danger fw-bold mb-3"})
                <div class="form-group row">
                    <label class="col-md-2 col-form-label fw-bold">Nazwa roli</label>
                    <div class="col-md-6">
                        <input type="text" name="roleName" class="form-control" required />
                    </div>
                </div>
                <div class="mt-3">
                    <input type="submit" value="Zapisz" class="btn btn-primary" />
                    @Html.ActionLink("Anuluj", "Index", null, new { @class = "btn btn-secondary ms-2" })
                </div>
            }
</div>

