@model InzV3.Models.DevCategory
<div class="mt-4">
    <h2>Dodaj nową kategorię urządzeń</h2>
    <hr />

    @using (Html.BeginForm())
    {
        @Html.AntiForgeryToken()
        <div class="form-horizontal">
            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                <div class="form-group row mb-3">
                    @Html.LabelFor(model => model.category_name, htmlAttributes: new { @class = "col-form-label col-md-2 fw-bold" })
                    <div class="col-md-6">
                        @Html.EditorFor(model => model.category_name, new { htmlAttributes = new { @class = "form-control", placeholder = "np. Laptop, Hub USB, Drukarka..." } })
                        @Html.ValidationMessageFor(model => model.category_name, "", new { @class = "text-danger" })

                    </div>
                </div>
                <div class="form-group row">
                    <div class="offset-md-2 col-md-10">
                        <input type="submit" value="Zapisz" class="btn btn-primary" />
                        @Html.ActionLink("Powrót do listy", "Index", null, new { @class = "btn btn-secondary ms-2" })
                    </div>
                </div>
        </div>
      }
</div>
