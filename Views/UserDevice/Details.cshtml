@model InzV3.Models.DeviceModel
@using Microsoft.AspNet.Identity
@{
    ViewBag.Title = "Szczegóły urządzenia";
    var software = ViewBag.Software as List<InzV3.Models.SoftwareModel>;
    var ratings = ViewBag.Ratings as List<InzV3.Models.DeviceRating>;
    var currentUserId = User.Identity.GetUserId();
    Layout = "~/Views/Shared/_Layout.cshtml";
    Func<DateTime?, string> GetStatusColor = (endDate) =>
    {
        if (!endDate.HasValue)
            return "";
        var today = DateTime.Today;
        var date = endDate.Value.Date;
        if (date < today) return "text-danger fw-bold";
        if (date <= today.AddMonths(2)) return "text-warning fw-bold";
        return "";
    };
}
<h2 class="text-center">@ViewBag.Title</h2>
<hr/>
@if (TempData["ErrorMessage"] !=null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-3" role="alert">
                    <i class="bi bi-exclamation-octagon-fill"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }
<div class="row justify-content-center">
    <div class="col-lg-8 col-md-10">
        <div class="card mb-4">
            <div class="card-header bg-light"><h5 class="mb-0">Informacje o sprzęcie</h5></div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-5"> Id urządzenia</dt>
                    <dd class="col-sm-7">@Model.id_device</dd>

                    <dt class="col-sm-5">Marka i model</dt>
                    <dd class="col-sm-7">@Model.brand @Model.model</dd>

                    <dt class="col-sm-5">Numer seryjny</dt>
                    <dd class="col-sm-7">@Model.serial_num</dd>

                    <dt class="col-sm-5">Koniec gwarancji</dt>
                    <dd class="col-sm-7 mb-0">
                        <span class="@GetStatusColor(Model.warranty)">
                            @(Model.warranty.HasValue ? Model.warranty.Value.ToShortDateString(): "Brak danych")
                        </span>
                    </dd>
                </dl>


            </div>
        </div>
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light"><h5 class="mb-0">Obecne oceny</h5></div>
            <div class="card-body">
                @if (ratings != null && ratings.Any())
                {
                    foreach (var r in ratings)
                    {
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>@r.category_name</span>
                            <span class="badge bg-info text-dark">@r.rating_value/5</span>
                        </div>
                    }
                }
                @if (Model.id_user == currentUserId)
                {
                    <button class="btn btn-warning w-100" data-bs-toggle="modal" data-bs-target="#ratingModal">
                        Oceń urządzenie
                    </button>
                }
            </div>
        </div>
        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-light"><h5 class="mb-0">Przypisane oprogramowanie</h5></div>
            <div class="card-body">
                @if (software != null && software.Any())
                {
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Nazwa</th>
                                <th>Data ważności</th>
                                <th>Numer seryjny</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var s in software)
                            {
                                <tr>
                                    <td>@s.software_name</td>
                                    <td>
                                        <span class="@GetStatusColor(s.license_end_date)">
                                            @(s.license_end_date.HasValue ? s.license_end_date.Value.ToShortDateString() : "Bezterminowa")
                                        </span>
                                    </td>
                                    <td>@(string.IsNullOrEmpty(s.software_serial_number) ? "Brak" : s.software_serial_number)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <p class="text-muted">Brak przypisanego oprogramowania</p>
                }
            </div>
        </div>
        <button class=" btn btn-danger btn-lg w-100 mb-3 mt-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#ticketModal">
            <i class="bi bi-exclamation-triangle"></i> Zgłoś problem ze sprzętem
        </button>
        <p class="mt-3">
            <a class="btn btn-secondary" href="@Url.Action("Index", "Home")">Powrót do strony głównej</a>
        </p>
    </div>

</div>

<div class="modal fade" id="ticketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("Create", "Tickets", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="id_device" value="@Model.id_device" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title">Zgłoś problem ze sprzętem: @Model.brand @Model.model</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Krótki opis problemu</label>
                        <textarea class="form-control" name="description" rows="4" required placeholder="Opisz problem sprzętu:"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="submit" class="btn btn-danger">Wyślij</button>
                </div>
            }
        </div>
    </div>
</div>


<div class="modal fade" id="ratingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            @using (Html.BeginForm("SaveRatings", "UserDevice", FormMethod.Post))
            {
                @Html.AntiForgeryToken() <input type="hidden" name="id_device" value="@Model.id_device" />
                <div class="modal-header">
                    <h5 class="modal-title">Oceń parametry sprzętu</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    @foreach (var r in ratings)
                    {
                        <div class="mb-4">
                            <label class="form-label fw-bold d-flex justify-content-between align-items-center">
                                <span>@r.category_name</span>
                                <span class="badge bg-primary text-white">Ocena: <span id="val_@r.id_rating">@r.rating_value</span>/5</span>
                            </label>
                            <div class="d-flex  align-items-center mt-2">
                                <span class="text-danger small fw-semibold me-3" style="white-space: nowrap;" >
                                    Oceniam źle
                                </span>

                                <input type="range" class="form-range flex-grow-1"
                                       name="rating_@r.id_rating"
                                       min="1"
                                       max="5"
                                       step="1"
                                       value="@r.rating_value"
                                       oninput="document.getElementById('val_@r.id_rating').innerText=this.value">
                                <span class="text-success small fw-semibold ms-3" style="white-space: nowrap;">
                                    Oceniam dobrze
                                </span>
                            </div>
                        </div>
                    }
                </div>


                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Anuluj</button>
                    <button type="submit" class="btn btn-success">Zapisz oceny</button>
                </div>
            }
        </div>
    </div>
</div>
<div class="modal fade" id="autoTicketModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-danger shadow">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title"><i class="bi bi-exclamation-triangle-fill"></i> Automatyczne zgłoszenie zostało wysłane!</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Z powodu niskiej oceny sprzętu, oraz troskę o komfort pracy, system automatycznie zgłosił problem do serwisu.
                Niedługo obsługa serwisu skontaktuję się z Tobą w celu ustalenia, czy potrzebne są dalsze kroki.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">OK</button>
                <a href="@Url.Action("MyTickets", "Tickets")" class="btn btn-danger">Przejdź do zgłoszeń</a>
            </div>
        </div>
    </div> 
</div>
@*Wymuszanie ocenienia sprzętu*@
@section Scripts
    {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            var forceRating = '@(ViewBag.ForceRating == true ? "true" : "false")' === 'true';
            if (forceRating) {
                var modalEl = document.getElementById('ratingModal');
                var ratingModal = new bootstrap.Modal(modalEl, {
                    backdrop: 'static',
                    keyboard: false
                });
                var closeBtns = modalEl.querySelectorAll('.btn-close, .btn-secondary');
                closeBtns.forEach(function (btn) {
                    btn.style.display = 'none';
                });
                ratingModal.show();
            }
            var showAutoTicket = '@(TempData["AutoTicketCreated"] != null && (bool)TempData["AutoTicketCreated"])' === 'True';
            if (showAutoTicket) {
                var autoTicketModalEl = document.getElementById('autoTicketModal');
                var autoTicketModal = new bootstrap.Modal(autoTicketModalEl);
                autoTicketModal.show();
            }
        });
    </script>

    }
